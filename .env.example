# Copia este archivo como .env y completa tus credenciales

# === CORREO (IMAP/SMTP) ===
EMAIL_HOST=imap.gmail.com
EMAIL_PORT=993
EMAIL_USER=tu_correo@gmail.com
EMAIL_PASS=tu_app_password_de_gmail

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587

# === OLLAMA (LLM LOCAL) ===
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=mistral

# Tiempo máximo de espera por respuesta del modelo (segundos)
# Aumentar si la máquina es lenta o el modelo es grande
OLLAMA_TIMEOUT=300

# Correos que se clasifican por llamada al LLM
# Reducir a 3 si el modelo tarda demasiado (PC con poca RAM)
OLLAMA_BATCH_SIZE=5

# === CALENDARIO ===
# Ruta al archivo .ics exportado desde Google Calendar u otro
ICS_PATH=data/calendar.ics

# === REPORTE ===
# Correo destino para enviar el reporte (puede ser el mismo tuyo)
REPORT_EMAIL=tu_correo@gmail.com
